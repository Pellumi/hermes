<?xml version="1.0"?>
<robot name="hermes_hexacopter">
  <!-- Materials -->
  <material name="carbon_fiber">
    <color rgba="0.2 0.2 0.2 1" />
  </material>
  <material name="blue_body">
    <color rgba="0 0.2 0.8 1" />
  </material>
  <material name="orange_payload">
    <color rgba="1 0.5 0 1" />
  </material>
  <material name="red_motor">
    <color rgba="0.8 0.2 0.2 1" />
  </material>
  <material name="gray_electronics">
    <color rgba="0.5 0.5 0.5 1" />
  </material>
  <material name="black_camera">
    <color rgba="0.1 0.1 0.1 1" />
  </material>
  <material name="green_sensor">
    <color rgba="0.2 0.8 0.2 1" />
  </material>
  
  <!-- Base Link - Main Frame (Carbon Fiber Hexacopter) -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="1.2 1.2 0.15" />
      </geometry>
      <origin xyz="0 0 0.075" rpy="0 0 0" />
      <material name="carbon_fiber" />
    </visual>
    <collision>
      <geometry>
        <box size="1.2 1.2 0.15" />
      </geometry>
      <origin xyz="0 0 0.075" rpy="0 0 0" />
    </collision>
    <inertial>
      <mass value="20.0" />
      <origin xyz="0 0 0.075" />
      <inertia ixx="2.4" iyy="2.4" izz="4.8" ixy="0" ixz="0" iyz="0" />
    </inertial>
  </link>
  
  <!-- Central Body Electronics Bay -->
  <link name="electronics_bay">
    <visual>
      <geometry>
        <cylinder radius="0.25" length="0.12" />
      </geometry>
      <origin xyz="0 0 0.06" rpy="0 0 0" />
      <!-- rpy means roll, pitch, yaw -->
      <material name="blue_body" />
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.25" length="0.12" />
      </geometry>
      <origin xyz="0 0 0.06" rpy="0 0 0" />
    </collision>
    <inertial>
      <mass value="3.0" />
      <origin xyz="0 0 0" />
      <inertia ixx="0.1" iyy="0.1" izz="0.19" ixy="0" ixz="0" iyz="0" />
    </inertial>
  </link>
  
  <joint name="electronics_bay_joint" type="fixed">
    <parent link="base_link" />
    <child link="electronics_bay" />
    <origin xyz="0 0 0.15" rpy="0 0 0" />
  </joint>
  
  <!-- Hexacopter Arms and Motors -->
  <!-- Motor positions at 60-degree intervals for perfect hexagon -->

  <!-- Motor 1 (Front) -->
  <link name="motor_1">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.08" />
      </geometry>
      <origin xyz="0 0 0.04" rpy="0 0 0" />
      <material name="red_motor" />
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.08" />
      </geometry>
      <origin xyz="0 0 0.04" rpy="0 0 0" />
    </collision>
    <inertial>
      <mass value="0.8" />
      <origin xyz="0 0 0" />
      <inertia ixx="0.01" iyy="0.01" izz="0.002" ixy="0" ixz="0" iyz="0" />
    </inertial>
  </link>

  <joint name="motor_1_joint" type="fixed">
    <parent link="base_link" />
    <child link="motor_1" />
    <origin xyz="0.52 0 0.15" rpy="0 0 0" />
  </joint>

  <!-- Propeller 1 -->
  <link name="propeller_1">
    <visual>
      <geometry>
        <cylinder radius="0.2" length="0.02" />
      </geometry>
      <origin xyz="0 0 0.01" rpy="0 0 0" />
      <material name="carbon_fiber" />
    </visual>
    <inertial>
      <mass value="0.1" />
      <origin xyz="0 0 0" />
      <inertia ixx="0.004" iyy="0.004" izz="0.004" ixy="0" ixz="0" iyz="0" />
    </inertial>
  </link>

  <joint name="propeller_1_joint" type="continuous">
    <parent link="motor_1" />
    <child link="propeller_1" />
    <origin xyz="0 0 0.08" rpy="0 0 0" />
    <axis xyz="0 0 1" />
  </joint>

  <!-- Motor 2 (Front Right) -->
  <link name="motor_2">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.08" />
      </geometry>
      <origin xyz="0 0 0.04" rpy="0 0 0" />
      <material name="red_motor" />
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.08" />
      </geometry>
      <origin xyz="0 0 0.04" rpy="0 0 0" />
    </collision>
    <inertial>
      <mass value="0.8" />
      <origin xyz="0 0 0" />
      <inertia ixx="0.01" iyy="0.01" izz="0.002" ixy="0" ixz="0" iyz="0" />
    </inertial>
  </link>

  <joint name="motor_2_joint" type="fixed">
    <parent link="base_link" />
    <child link="motor_2" />
    <origin xyz="0.26 0.45 0.15" rpy="0 0 0" />
  </joint>

  <!-- Propeller 2 -->
  <link name="propeller_2">
    <visual>
      <geometry>
        <cylinder radius="0.2" length="0.02" />
      </geometry>
      <origin xyz="0 0 0.01" rpy="0 0 0" />
      <material name="carbon_fiber" />
    </visual>
    <inertial>
      <mass value="0.1" />
      <origin xyz="0 0 0" />
      <inertia ixx="0.004" iyy="0.004" izz="0.004" ixy="0" ixz="0" iyz="0" />
    </inertial>
  </link>

  <joint name="propeller_2_joint" type="continuous">
    <parent link="motor_2" />
    <child link="propeller_2" />
    <origin xyz="0 0 0.08" rpy="0 0 0" />
    <axis xyz="0 0 1" />
  </joint>

  <!-- Motor 3 (Back Right) -->
  <link name="motor_3">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.08" />
      </geometry>
      <origin xyz="0 0 0.04" rpy="0 0 0" />
      <material name="red_motor" />
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.08" />
      </geometry>
      <origin xyz="0 0 0.04" rpy="0 0 0" />
    </collision>
    <inertial>
      <mass value="0.8" />
      <origin xyz="0 0 0" />
      <inertia ixx="0.01" iyy="0.01" izz="0.002" ixy="0" ixz="0" iyz="0" />
    </inertial>
  </link>

  <joint name="motor_3_joint" type="fixed">
    <parent link="base_link" />
    <child link="motor_3" />
    <origin xyz="-0.26 0.45 0.15" rpy="0 0 0" />
  </joint>

  <!-- Propeller 3 -->
  <link name="propeller_3">
    <visual>
      <geometry>
        <cylinder radius="0.2" length="0.02" />
      </geometry>
      <origin xyz="0 0 0.01" rpy="0 0 0" />
      <material name="carbon_fiber" />
    </visual>
    <inertial>
      <mass value="0.1" />
      <origin xyz="0 0 0" />
      <inertia ixx="0.004" iyy="0.004" izz="0.004" ixy="0" ixz="0" iyz="0" />
    </inertial>
  </link>

  <joint name="propeller_3_joint" type="continuous">
    <parent link="motor_3" />
    <child link="propeller_3" />
    <origin xyz="0 0 0.08" rpy="0 0 0" />
    <axis xyz="0 0 1" />
  </joint>

  <!-- Motor 4 (Back) -->
  <link name="motor_4">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.08" />
      </geometry>
      <origin xyz="0 0 0.04" rpy="0 0 0" />
      <material name="red_motor" />
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.08" />
      </geometry>
      <origin xyz="0 0 0.04" rpy="0 0 0" />
    </collision>
    <inertial>
      <mass value="0.8" />
      <origin xyz="0 0 0" />
      <inertia ixx="0.01" iyy="0.01" izz="0.002" ixy="0" ixz="0" iyz="0" />
    </inertial>
  </link>

  <joint name="motor_4_joint" type="fixed">
    <parent link="base_link" />
    <child link="motor_4" />
    <origin xyz="-0.52 0 0.15" rpy="0 0 0" />
  </joint>

  <!-- Propeller 4 -->
  <link name="propeller_4">
    <visual>
      <geometry>
        <cylinder radius="0.2" length="0.02" />
      </geometry>
      <origin xyz="0 0 0.01" rpy="0 0 0" />
      <material name="carbon_fiber" />
    </visual>
    <inertial>
      <mass value="0.1" />
      <origin xyz="0 0 0" />
      <inertia ixx="0.004" iyy="0.004" izz="0.004" ixy="0" ixz="0" iyz="0" />
    </inertial>
  </link>

  <joint name="propeller_4_joint" type="continuous">
    <parent link="motor_4" />
    <child link="propeller_4" />
    <origin xyz="0 0 0.08" rpy="0 0 0" />
    <axis xyz="0 0 1" />
  </joint>

  <!-- Motor 5 (Back Left) -->
  <link name="motor_5">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.08" />
      </geometry>
      <origin xyz="0 0 0.04" rpy="0 0 0" />
      <material name="red_motor" />
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.08" />
      </geometry>
      <origin xyz="0 0 0.04" rpy="0 0 0" />
    </collision>
    <inertial>
      <mass value="0.8" />
      <origin xyz="0 0 0" />
      <inertia ixx="0.01" iyy="0.01" izz="0.002" ixy="0" ixz="0" iyz="0" />
    </inertial>
  </link>

  <joint name="motor_5_joint" type="fixed">
    <parent link="base_link" />
    <child link="motor_5" />
    <origin xyz="-0.26 -0.45 0.15" rpy="0 0 0" />
  </joint>

  <!-- Propeller 5 -->
  <link name="propeller_5">
    <visual>
      <geometry>
        <cylinder radius="0.2" length="0.02" />
      </geometry>
      <origin xyz="0 0 0.01" rpy="0 0 0" />
      <material name="carbon_fiber" />
    </visual>
    <inertial>
      <mass value="0.1" />
      <origin xyz="0 0 0" />
      <inertia ixx="0.004" iyy="0.004" izz="0.004" ixy="0" ixz="0" iyz="0" />
    </inertial>
  </link>

  <joint name="propeller_5_joint" type="continuous">
    <parent link="motor_5" />
    <child link="propeller_5" />
    <origin xyz="0 0 0.08" rpy="0 0 0" />
    <axis xyz="0 0 1" />
  </joint>

  <!-- Motor 6 (Front Left) -->
  <link name="motor_6">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.08" />
      </geometry>
      <origin xyz="0 0 0.04" rpy="0 0 0" />
      <material name="red_motor" />
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.08" />
      </geometry>
      <origin xyz="0 0 0.04" rpy="0 0 0" />
    </collision>
    <inertial>
      <mass value="0.8" />
      <origin xyz="0 0 0" />
      <inertia ixx="0.01" iyy="0.01" izz="0.002" ixy="0" ixz="0" iyz="0" />
    </inertial>
  </link>

  <joint name="motor_6_joint" type="fixed">
    <parent link="base_link" />
    <child link="motor_6" />
    <origin xyz="0.26 -0.45 0.15" rpy="0 0 0" />
  </joint>

  <!-- Propeller 6 -->
  <link name="propeller_6">
    <visual>
      <geometry>
        <cylinder radius="0.2" length="0.02" />
      </geometry>
      <origin xyz="0 0 0.01" rpy="0 0 0" />
      <material name="carbon_fiber" />
    </visual>
    <inertial>
      <mass value="0.1" />
      <origin xyz="0 0 0" />
      <inertia ixx="0.004" iyy="0.004" izz="0.004" ixy="0" ixz="0" iyz="0" />
    </inertial>
  </link>

  <joint name="propeller_6_joint" type="continuous">
    <parent link="motor_6" />
    <child link="propeller_6" />
    <origin xyz="0 0 0.08" rpy="0 0 0" />
    <axis xyz="0 0 1" />
  </joint>

  <!-- Payload Container (40cm x 30cm x 25cm) -->
  <link name="payload_container">
    <visual>
      <geometry>
        <box size="0.40 0.30 0.25" />
      </geometry>
      <origin xyz="0 0 0.125" rpy="0 0 0" />
      <material name="orange_payload" />
    </visual>
    <collision>
      <geometry>
        <box size="0.40 0.30 0.25" />
      </geometry>
      <origin xyz="0 0 0.125" rpy="0 0 0" />
    </collision>
    <inertial>
      <mass value="5.0" />
      <origin xyz="0 0 0.125" />
      <inertia ixx="0.1" iyy="0.08" izz="0.05" ixy="0" ixz="0" iyz="0" />
    </inertial>
  </link>

  <joint name="payload_joint" type="fixed">
    <parent link="base_link" />
    <child link="payload_container" />
    <origin xyz="0 0 -0.25" rpy="0 0 0" />
  </joint>

  <!-- NVIDIA Jetson Orin Nano -->
  <link name="jetson_orin">
    <visual>
      <geometry>
        <box size="0.1 0.08 0.03" />
      </geometry>
      <origin xyz="0 0 0.015" rpy="0 0 0" />
      <material name="green_sensor" />
    </visual>
    <collision>
      <geometry>
        <box size="0.1 0.08 0.03" />
      </geometry>
      <origin xyz="0 0 0.015" rpy="0 0 0" />
    </collision>
    <inertial>
      <mass value="0.5" />
      <origin xyz="0 0 0" />
      <inertia ixx="0.001" iyy="0.001" izz="0.002" ixy="0" ixz="0" iyz="0" />
    </inertial>
  </link>

  <joint name="jetson_joint" type="fixed">
    <parent link="electronics_bay" />
    <child link="jetson_orin" />
    <origin xyz="0.08 0 0.06" rpy="0 0 0" />
  </joint>

  <!-- Pixhawk Flight Controller -->
  <link name="pixhawk">
    <visual>
      <geometry>
        <box size="0.08 0.05 0.02" />
      </geometry>
      <origin xyz="0 0 0.01" rpy="0 0 0" />
      <material name="gray_electronics" />
    </visual>
    <collision>
      <geometry>
        <box size="0.08 0.05 0.02" />
      </geometry>
      <origin xyz="0 0 0.01" rpy="0 0 0" />
    </collision>
    <inertial>
      <mass value="0.1" />
      <origin xyz="0 0 0" />
      <inertia ixx="0.0001" iyy="0.0001" izz="0.0002" ixy="0" ixz="0" iyz="0" />
    </inertial>
  </link>

  <joint name="pixhawk_joint" type="fixed">
    <parent link="electronics_bay" />
    <child link="pixhawk" />
    <origin xyz="-0.08 0 0.06" rpy="0 0 0" />
  </joint>

  <!-- Navigation Camera (4K 60fps with gimbal) -->
  <link name="nav_camera">
    <visual>
      <geometry>
        <cylinder radius="0.03" length="0.08" />
      </geometry>
      <origin xyz="0 0 0.04" rpy="0 0 0" />
      <material name="black_camera" />
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.03" length="0.08" />
      </geometry>
      <origin xyz="0 0 0.04" rpy="0 0 0" />
    </collision>
    <inertial>
      <mass value="0.3" />
      <origin xyz="0 0 0" />
      <inertia ixx="0.001" iyy="0.001" izz="0.0005" ixy="0" ixz="0" iyz="0" />
    </inertial>
  </link>

  <joint name="nav_camera_joint" type="revolute">
    <parent link="electronics_bay" />
    <child link="nav_camera" />
    <origin xyz="0 0 -0.12" rpy="0 1.57 0" />
    <axis xyz="0 1 0" />
    <limit lower="-1.57" upper="0.785" effort="10" velocity="1" />
  </joint>

  <!-- Payload External Camera -->
  <link name="payload_ext_camera">
    <visual>
      <geometry>
        <cylinder radius="0.02" length="0.04" />
      </geometry>
      <origin xyz="0 0 0.02" rpy="0 0 0" />
      <material name="black_camera" />
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.02" length="0.04" />
      </geometry>
      <origin xyz="0 0 0.02" rpy="0 0 0" />
    </collision>
    <inertial>
      <mass value="0.1" />
      <origin xyz="0 0 0" />
      <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" ixz="0" iyz="0" />
    </inertial>
  </link>

  <joint name="payload_ext_camera_joint" type="fixed">
    <parent link="payload_container" />
    <child link="payload_ext_camera" />
    <origin xyz="0.2 0 0.125" rpy="0 1.57 0" />
  </joint>

  <!-- Payload Internal Camera -->
  <link name="payload_int_camera">
    <visual>
      <geometry>
        <cylinder radius="0.015" length="0.03" />
      </geometry>
      <origin xyz="0 0 0.015" rpy="0 0 0" />
      <material name="black_camera" />
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.015" length="0.03" />
      </geometry>
      <origin xyz="0 0 0.015" rpy="0 0 0" />
    </collision>
    <inertial>
      <mass value="0.05" />
      <origin xyz="0 0 0" />
      <inertia ixx="0.00005" iyy="0.00005" izz="0.00005" ixy="0" ixz="0" iyz="0" />
    </inertial>
  </link>

  <joint name="payload_int_camera_joint" type="fixed">
    <parent link="payload_container" />
    <child link="payload_int_camera" />
    <origin xyz="0 0 0.22" rpy="0 0 0" />
  </joint>

  <!-- LIDAR Sensor -->
  <link name="lidar">
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.06" />
      </geometry>
      <origin xyz="0 0 0.03" rpy="0 0 0" />
      <material name="green_sensor" />
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.04" length="0.06" />
      </geometry>
      <origin xyz="0 0 0.03" rpy="0 0 0" />
    </collision>
    <inertial>
      <mass value="0.2" />
      <origin xyz="0 0 0" />
      <inertia ixx="0.0005" iyy="0.0005" izz="0.0003" ixy="0" ixz="0" iyz="0" />
    </inertial>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="electronics_bay" />
    <child link="lidar" />
    <origin xyz="0 0 0.18" rpy="0 0 0" />
  </joint>

  <!-- GPS Antenna -->
  <link name="gps_antenna">
    <visual>
      <geometry>
        <cylinder radius="0.025" length="0.01" />
      </geometry>
      <origin xyz="0 0 0.005" rpy="0 0 0" />
      <material name="gray_electronics" />
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.025" length="0.01" />
      </geometry>
      <origin xyz="0 0 0.005" rpy="0 0 0" />
    </collision>
    <inertial>
      <mass value="0.05" />
      <origin xyz="0 0 0" />
      <inertia ixx="0.00001" iyy="0.00001" izz="0.00001" ixy="0" ixz="0" iyz="0" />
    </inertial>
  </link>

  <joint name="gps_joint" type="fixed">
    <parent link="electronics_bay" />
    <child link="gps_antenna" />
    <origin xyz="0.15 0 0.18" rpy="0 0 0" />
  </joint>

  <!-- Communication Module (4G/5G) -->
  <link name="comm_module">
    <visual>
      <geometry>
        <box size="0.06 0.04 0.02" />
      </geometry>
      <origin xyz="0 0 0.01" rpy="0 0 0" />
      <material name="gray_electronics" />
    </visual>
    <collision>
      <geometry>
        <box size="0.06 0.04 0.02" />
      </geometry>
      <origin xyz="0 0 0.01" rpy="0 0 0" />
    </collision>
    <inertial>
      <mass value="0.1" />
      <origin xyz="0 0 0" />
      <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" ixz="0" iyz="0" />
    </inertial>
  </link>

  <joint name="comm_module_joint" type="fixed">
    <parent link="electronics_bay" />
    <child link="comm_module" />
    <origin xyz="0 0.15 0.06" rpy="0 0 0" />
  </joint>

  <!-- Batteries (2x 6S LiPo) -->
  <link name="battery_1">
    <visual>
      <geometry>
        <box size="0.15 0.05 0.04" />
      </geometry>
      <origin xyz="0 0 0.02" rpy="0 0 0" />
      <material name="gray_electronics" />
    </visual>
    <collision>
      <geometry>
        <box size="0.15 0.05 0.04" />
      </geometry>
      <origin xyz="0 0 0.02" rpy="0 0 0" />
    </collision>
    <inertial>
      <mass value="1.2" />
      <origin xyz="0 0 0" />
      <inertia ixx="0.01" iyy="0.01" izz="0.02" ixy="0" ixz="0" iyz="0" />
    </inertial>
  </link>

  <joint name="battery_1_joint" type="fixed">
    <parent link="electronics_bay" />
    <child link="battery_1" />
    <origin xyz="0.1 -0.1 -0.02" rpy="0 0 0" />
  </joint>

  <link name="battery_2">
    <visual>
      <geometry>
        <box size="0.15 0.05 0.04" />
      </geometry>
      <origin xyz="0 0 0.02" rpy="0 0 0" />
      <material name="gray_electronics" />
    </visual>
    <collision>
      <geometry>
        <box size="0.15 0.05 0.04" />
      </geometry>
      <origin xyz="0 0 0.02" rpy="0 0 0" />
    </collision>
    <inertial>
      <mass value="1.2" />
      <origin xyz="0 0 0" />
      <inertia ixx="0.01" iyy="0.01" izz="0.02" ixy="0" ixz="0" iyz="0" />
    </inertial>
  </link>

  <joint name="battery_2_joint" type="fixed">
