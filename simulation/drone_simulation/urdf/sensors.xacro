<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- Include materials -->
    <xacro:include filename="./materials.xacro" />

    <!-- ==================== -->
    <!--  Vision Sensors  -->
    <!-- ==================== -->

    <!-- Navigation Camera (4K 60fps with gimbal) -->
    <link name="nav_camera">
        <visual>
            <geometry>
                <cylinder radius="0.03" length="0.08" />  <!-- 60mm long x 60mm diameter -->
            </geometry>
            <origin xyz="0 0 0.04" rpy="0 0 0" />
            <material name="black_camera" />
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.03" length="0.08" />
            </geometry>
        </collision>
        <inertial>
            <mass value="0.3" />
            <origin xyz="0 0 0" />
            <inertia ixx="0.001" iyy="0.001" izz="0.0005" ixy="0" ixz="0" iyz="0" />
        </inertial>
    </link>

    <!-- Gimbal System for Navigation Camera -->
    <link name="camera_gimbal_yaw">
        <visual>
            <geometry>
                <box size="0.05 0.05 0.03" />
            </geometry>
            <material name="gray_electronics" />
        </visual>
    </link>

    <joint name="gimbal_yaw_joint" type="revolute">
        <parent link="electronics_bay" />
        <child link="camera_gimbal_yaw" />
        <axis xyz="0 0 1" />
        <limit lower="-3.14" upper="3.14" effort="10" velocity="3.0" />
        <dynamics damping="0.1" friction="0.01" />
    </joint>

    <joint name="nav_camera_joint" type="revolute">
        <parent link="camera_gimbal_yaw" />
        <child link="nav_camera" />
        <origin xyz="0 0 0" rpy="0 1.57 0" />
        <axis xyz="0 1 0" />
        <limit lower="-1.57" upper="0.785" effort="10" velocity="3.0" />
        <dynamics damping="0.1" friction="0.01" />
    </joint>

    <!-- Gazebo Camera Plugin -->
    <gazebo reference="nav_camera">
        <sensor name="nav_camera_sensor" type="camera">
            <update_rate>60</update_rate>
            <camera>
                <horizontal_fov>1.3962634</horizontal_fov>  <!-- 80° FOV -->
                <image>
                    <width>3840</width>  <!-- 4K resolution -->
                    <height>2160</height>
                    <format>R8G8B8</format>
                </image>
                <clip>
                    <near>0.1</near>
                    <far>100</far>
                </clip>
                <noise>
                    <type>gaussian</type>
                    <mean>0.0</mean>
                    <stddev>0.007</stddev>
                </noise>
            </camera>
            <plugin filename="libgazebo_ros_camera.so" name="nav_camera_plugin">
                <ros>
                    <namespace>/hermes</namespace>
                    <remapping>image_raw:=nav_camera/image_raw</remapping>
                </ros>
                <camera_name>nav_camera</camera_name>
                <frame_name>nav_camera_optical</frame_name>
                <hack_baseline>0.07</hack_baseline>
            </plugin>
        </sensor>
    </gazebo>

    <!-- ==================== -->
    <!--  LIDAR Sensor  -->
    <!-- ==================== -->

    <link name="lidar">
        <visual>
            <geometry>
                <cylinder radius="0.04" length="0.06" />
            </geometry>
            <origin xyz="0 0 0.03" rpy="0 0 0" />
            <material name="green_sensor" />
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.04" length="0.06" />
            </geometry>
        </collision>
        <inertial>
            <mass value="0.2" />
            <origin xyz="0 0 0" />
            <inertia ixx="0.0005" iyy="0.0005" izz="0.0003" ixy="0" ixz="0" iyz="0" />
        </inertial>
    </link>

    <joint name="lidar_joint" type="fixed">
        <parent link="electronics_bay" />
        <child link="lidar" />
        <origin xyz="0 0 0.18" rpy="0 0 0" />
    </joint>

    <!-- Gazebo LIDAR Plugin -->
    <gazebo reference="lidar">
        <sensor name="lidar_sensor" type="ray">
            <pose>0 0 0.03 0 0 0</pose>
            <visualize>true</visualize>
            <update_rate>20</update_rate>
            <ray>
                <scan>
                    <horizontal>
                        <samples>720</samples>  <!-- 2 samples per degree -->
                        <resolution>1.0</resolution>
                        <min_angle>-3.1415926</min_angle>  <!-- -180° -->
                        <max_angle>3.1415926</max_angle>   <!-- +180° -->
                    </horizontal>
                    <vertical>
                        <samples>16</samples>
                        <resolution>1.0</resolution>
                        <min_angle>-0.261799</min_angle>  <!-- -15° -->
                        <max_angle>0.261799</max_angle>   <!-- +15° -->
                    </vertical>
                </scan>
                <range>
                    <min>0.10</min>
                    <max>30.0</max>
                    <resolution>0.01</resolution>
                </range>
                <noise>
                    <type>gaussian</type>
                    <mean>0.0</mean>
                    <stddev>0.01</stddev>
                </noise>
            </ray>
            <plugin filename="libgazebo_ros_ray_sensor.so" name="lidar_plugin">
                <ros>
                    <namespace>/hermes</namespace>
                    <remapping>scan:=lidar/scan</remapping>
                </ros>
                <frame_name>lidar_link</frame_name>
                <topic_name>scan</topic_name>
            </plugin>
        </sensor>
    </gazebo>

    <!-- ==================== -->
    <!--  GPS Antenna  -->
    <!-- ==================== -->

    <link name="gps_antenna">
        <visual>
            <geometry>
                <cylinder radius="0.025" length="0.01" />
            </geometry>
            <origin xyz="0 0 0.005" rpy="0 0 0" />
            <material name="gray_electronics" />
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.025" length="0.01" />
            </geometry>
        </collision>
    </link>

    <joint name="gps_joint" type="fixed">
        <parent link="electronics_bay" />
        <child link="gps_antenna" />
        <origin xyz="0.15 0 0.18" rpy="0 0 0" />
    </joint>

    <!-- ==================== -->
    <!--  Ultrasonic Sensors  -->
    <!-- ==================== -->

    <xacro:macro name="ultrasonic_sensor" params="name xyz rpy">
        <link name="${name}_ultrasonic">
            <visual>
                <geometry>
                    <box size="0.02 0.02 0.01" />
                </geometry>
                <material name="green_sensor" />
            </visual>
            <collision>
                <geometry>
                    <box size="0.02 0.02 0.01" />
                </geometry>
            </collision>
        </link>

        <joint name="${name}_ultrasonic_joint" type="fixed">
            <parent link="base_link" />
            <child link="${name}_ultrasonic" />
            <origin xyz="${xyz}" rpy="${rpy}" />
        </joint>

        <!-- Gazebo Ultrasonic Plugin -->
        <gazebo reference="${name}_ultrasonic">
            <sensor name="${name}_ultrasonic_sensor" type="ray">
                <pose>0 0 0 0 0 0</pose>
                <visualize>true</visualize>
                <update_rate>20</update_rate>
                <ray>
                    <scan>
                        <horizontal>
                            <samples>5</samples>
                            <resolution>1.0</resolution>
                            <min_angle>-0.05</min_angle>
                            <max_angle>0.05</max_angle>
                        </horizontal>
                        <vertical>
                            <samples>5</samples>
                            <resolution>1.0</resolution>
                            <min_angle>-0.05</min_angle>
                            <max_angle>0.05</max_angle>
                        </vertical>
                    </scan>
                    <range>
                        <min>0.02</min>
                        <max>5.0</max>
                        <resolution>0.01</resolution>
                    </range>
                    <noise>
                        <type>gaussian</type>
                        <mean>0.0</mean>
                        <stddev>0.01</stddev>
                    </noise>
                </ray>
                <plugin filename="libgazebo_ros_ray_sensor.so" name="${name}_ultrasonic_plugin">
                    <ros>
                        <namespace>/hermes</namespace>
                        <remapping>range:=ultrasonic/${name}/range</remapping>
                    </ros>
                    <frame_name>${name}_ultrasonic_link</frame_name>
                </plugin>
            </sensor>
        </gazebo>
    </xacro:macro>

    <!-- Downward-facing ultrasonic for altitude -->
    <xacro:ultrasonic_sensor name="altitude" xyz="0 0 -0.1" rpy="0 1.57 0" />

    <!-- Forward-facing ultrasonic for obstacle detection -->
    <xacro:ultrasonic_sensor name="front" xyz="0.6 0 0.1" rpy="0 0 0" />

    <!-- ==================== -->
    <!--  Optical Flow Sensor  -->
    <!-- ==================== -->

    <link name="optical_flow">
        <visual>
            <geometry>
                <box size="0.02 0.02 0.005" />
            </geometry>
            <material name="black_camera" />
        </visual>
    </link>

    <joint name="optical_flow_joint" type="fixed">
        <parent link="base_link" />
        <child link="optical_flow" />
        <origin xyz="0 0 -0.15" rpy="0 0 0" />
    </joint>

    <!-- Gazebo Optical Flow Plugin -->
    <gazebo reference="optical_flow">
        <sensor name="optical_flow_sensor" type="opticalflow">
            <update_rate>60</update_rate>
            <camera>
                <image>
                    <width>64</width>
                    <height>64</height>
                </image>
                <clip>
                    <near>0.1</near>
                    <far>10.0</far>
                </clip>
                <noise>
                    <type>gaussian</type>
                    <mean>0.0</mean>
                    <stddev>0.007</stddev>
                </noise>
            </camera>
            <plugin filename="libgazebo_ros_opticalflow.so" name="optical_flow_plugin">
                <ros>
                    <namespace>/hermes</namespace>
                    <remapping>optical_flow:=mavros/px4flow/raw/optical_flow</remapping>
                </ros>
                <output_rate>60</output_rate>
                <f>250</f>  <!-- focal length in pixels -->
                <hack_baseline>0.1</hack_baseline>
            </plugin>
        </sensor>
    </gazebo>

    <!-- ==================== -->
    <!--  Time-of-Flight Sensors  -->
    <!-- ==================== -->

    <xacro:macro name="tof_sensor" params="name xyz rpy">
        <link name="${name}_tof">
            <visual>
                <geometry>
                    <box size="0.015 0.015 0.005" />
                </geometry>
                <material name="green_sensor" />
            </visual>
        </link>

        <joint name="${name}_tof_joint" type="fixed">
            <parent link="base_link" />
            <child link="${name}_tof" />
            <origin xyz="${xyz}" rpy="${rpy}" />
        </joint>

        <!-- Gazebo ToF Plugin -->
        <gazebo reference="${name}_tof">
            <sensor name="${name}_tof_sensor" type="ray">
                <pose>0 0 0 0 0 0</pose>
                <visualize>true</visualize>
                <update_rate>30</update_rate>
                <ray>
                    <scan>
                        <horizontal>
                            <samples>1</samples>
                            <resolution>1.0</resolution>
                            <min_angle>0</min_angle>
                            <max_angle>0</max_angle>
                        </horizontal>
                        <vertical>
                            <samples>1</samples>
                            <resolution>1.0</resolution>
                            <min_angle>0</min_angle>
                            <max_angle>0</max_angle>
                        </vertical>
                    </scan>
                    <range>
                        <min>0.01</min>
                        <max>10.0</max>
                        <resolution>0.001</resolution>
                    </range>
                    <noise>
                        <type>gaussian</type>
                        <mean>0.0</mean>
                        <stddev>0.01</stddev>
                    </noise>
                </ray>
                <plugin filename="libgazebo_ros_ray_sensor.so" name="${name}_tof_plugin">
                    <ros>
                        <namespace>/hermes</namespace>
                        <remapping>range:=tof/${name}/range</remapping>
                    </ros>
                    <frame_name>${name}_tof_link</frame_name>
                </plugin>
            </sensor>
        </gazebo>
    </xacro:macro>

    <!-- Downward-facing ToF for precision landing -->
    <xacro:tof_sensor name="tof_down" xyz="0 0 -0.15" rpy="0 0 0" />

    <!-- Forward-facing ToF for obstacle detection -->
    <xacro:tof_sensor name="tof_front" xyz="0.6 0 0.1" rpy="0 0 0" />
</robot>