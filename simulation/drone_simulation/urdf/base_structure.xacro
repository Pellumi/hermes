<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- Constant declaration -->
    <xacro:property name="M_PI" value="3.1415926535897931" />
    <xacro:property name="base_length" value="1.2" />  <!-- values in meters -->
    <xacro:property name="base_width" value="1.2" />
    <xacro:property name="base_height" value="0.15" />
    <xacro:property name="arm_length" value="0.6" />
    <xacro:property name="arm_thickness" value="0.04" />

    <!-- Main Base Link -->
    <link name="base_link">
        <visual>
            <geometry>
                <box size="${base_length} ${base_width} ${base_height}" />
            </geometry>
            <origin xyz="0 0 ${base_height/2}" rpy="0 0 0" />
            <material name="carbon_fiber" />
        </visual>

        <collision>
            <geometry>
                <box size="${base_length} ${base_width} ${base_height}" />
            </geometry>
            <origin xyz="0 0 ${base_height/2}" rpy="0 0 0" />
        </collision>

        <inertial>
            <mass value="5.0" />
            <origin xyz="0 0 ${base_height/2}" />
            <inertia
                ixx="${(mass/12) * (base_width**2 + base_height**2)}"
                iyy="${(mass/12) * (base_length**2 + base_height**2)}"
                izz="${(mass/12) * (base_length**2 + base_width**2)}"
                ixy="0" ixz="0" iyz="0" />
        </inertial>
    </link>

    <!-- Hexagonal Arms (6x) -->
    <xacro:macro name="hexacopter_arm" params="arm_id angle">
        <link name="arm_${arm_id}">
            <visual>
                <geometry>
                    <box size="${arm_length} ${arm_thickness} ${arm_thickness}" />
                </geometry>
                <origin xyz="${arm_length/2} 0 0" rpy="0 0 0" />
                <material name="carbon_fiber" />
            </visual>
            <collision>
                <geometry>
                    <box size="${arm_length} ${arm_thickness} ${arm_thickness}" />
                </geometry>
                <origin xyz="${arm_length/2} 0 0" rpy="0 0 0" />
            </collision>
            <inertial>
                <mass value="0.5" />
                <origin xyz="${arm_length/2} 0 0" />
                <inertia
                    ixx="0.001" iyy="0.1" izz="0.1"
                    ixy="0" ixz="0" iyz="0" />
            </inertial>
        </link>

        <joint name="arm_${arm_id}_joint" type="fixed">
            <parent link="base_link" />
            <child link="arm_${arm_id}" />
            <origin xyz="${cos(angle)*base_length/2} ${sin(angle)*base_width/2} ${base_height}"
                rpy="0 0 ${angle}" />
        </joint>
    </xacro:macro>

    <!-- 6 arms at 60° intervals -->
    <xacro:hexacopter_arm arm_id="1" angle="${0 * M_PI/3}" />
    <xacro:hexacopter_arm arm_id="2" angle="${1 * M_PI/3}" />
    <xacro:hexacopter_arm arm_id="3" angle="${2 * M_PI/3}" />
    <xacro:hexacopter_arm arm_id="4" angle="${3 * M_PI/3}" />
    <xacro:hexacopter_arm arm_id="5" angle="${4 * M_PI/3}" />
    <xacro:hexacopter_arm arm_id="6" angle="${5 * M_PI/3}" />

    <!-- Landing Gear -->
    <xacro:macro name="landing_gear" params="prefix x y">
        <link name="${prefix}_landing_gear">
            <visual>
                <geometry>
                    <cylinder radius="0.02" length="0.2" />
                </geometry>
                <origin xyz="0 0 -0.1" rpy="0 0 0" />
                <material name="carbon_fiber" />
            </visual>
            <collision>
                <geometry>
                    <cylinder radius="0.02" length="0.2" />
                </geometry>
                <origin xyz="0 0 -0.1" rpy="0 0 0" />
            </collision>
            <inertial>
                <mass value="0.2" />
                <origin xyz="0 0 -0.1" />
                <inertia ixx="0.001" iyy="0.001" izz="0.0001" ixy="0" ixz="0" iyz="0" />
            </inertial>
        </link>

        <joint name="${prefix}_landing_gear_joint" type="fixed">
            <parent link="base_link" />
            <child link="${prefix}_landing_gear" />
            <origin xyz="${x} ${y} 0" rpy="0 0 0" />
        </joint>

        <!-- Gazebo properties for shock absorption -->
        <gazebo reference="${prefix}_landing_gear">
            <mu1>1.0</mu1>
            <mu2>1.0</mu2>
            <kp>100000</kp>
            <kd>1000</kd>
            <material>Gazebo/Grey</material>
        </gazebo>
    </xacro:macro>

    <!-- Triple landing gear (tripod configuration) -->
    <xacro:landing_gear prefix="front" x="0.4" y="0" />
    <xacro:landing_gear prefix="left" x="-0.2" y="0.35" />
    <xacro:landing_gear prefix="right" x="-0.2" y="-0.35" />

    <!-- Central Electronics Bay -->
    <link name="electronics_bay">
        <visual>
            <geometry>
                <cylinder radius="0.25" length="0.12" />
            </geometry>
            <origin xyz="0 0 0.06" rpy="0 0 0" />
            <material name="blue_body" />
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.25" length="0.12" />
            </geometry>
            <origin xyz="0 0 0.06" rpy="0 0 0" />
        </collision>
        <inertial>
            <mass value="1.5" />
            <origin xyz="0 0 0" />
            <inertia ixx="0.05" iyy="0.05" izz="0.09" ixy="0" ixz="0" iyz="0" />
        </inertial>
    </link>

    <joint name="electronics_bay_joint" type="fixed">
        <parent link="base_link" />
        <child link="electronics_bay" />
        <origin xyz="0 0 ${base_height}" rpy="0 0 0" />
    </joint>

    <!-- Gazebo plugins for base link -->
    <gazebo reference="base_link">
        <turnGravityOff>false</turnGravityOff>
        <selfCollide>false</selfCollide>
        <mu1>0.3</mu1>
        <mu2>0.3</mu2>
    </gazebo>
</robot>