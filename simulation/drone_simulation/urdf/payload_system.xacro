<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- Include materials -->
    <xacro:include filename="./materials.xacro" />

    <!-- ==================== -->
    <!--  Payload Container  -->
    <!-- ==================== -->

    <!-- Main Container (40x30x25cm) -->
    <link name="payload_container">
        <visual>
            <geometry>
                <box size="0.40 0.30 0.25" />  <!-- 40x30x25cm -->
            </geometry>
            <origin xyz="0 0 0.125" rpy="0 0 0" />
            <material name="orange_payload" />
        </visual>
        <collision>
            <geometry>
                <box size="0.40 0.30 0.25" />
            </geometry>
            <origin xyz="0 0 0.125" rpy="0 0 0" />
        </collision>
        <inertial>
            <mass value="1.5" />  <!-- Container weight without payload -->
            <origin xyz="0 0 0.125" />
            <inertia ixx="0.1" iyy="0.08" izz="0.05" ixy="0" ixz="0" iyz="0" />
        </inertial>
    </link>

    <joint name="payload_joint" type="fixed">
        <parent link="base_link" />
        <child link="payload_container" />
        <origin xyz="0 0 -0.25" rpy="0 0 0" />
    </joint>

    <!-- ==================== -->
    <!--  Payload Cameras  -->
    <!-- ==================== -->

    <!-- External Payload Camera (1080p) -->
    <link name="payload_ext_camera">
        <visual>
            <geometry>
                <cylinder radius="0.02" length="0.04" />
            </geometry>
            <origin xyz="0 0 0.02" rpy="0 0 0" />
            <material name="black_camera" />
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.02" length="0.04" />
            </geometry>
        </collision>
        <inertial>
            <mass value="0.1" />
            <origin xyz="0 0 0" />
            <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" ixz="0" iyz="0" />
        </inertial>
    </link>

    <joint name="payload_ext_camera_joint" type="fixed">
        <parent link="payload_container" />
        <child link="payload_ext_camera" />
        <origin xyz="0.2 0 0.125" rpy="0 1.57 0" />
    </joint>

    <!-- Gazebo Camera Plugin for External Camera -->
    <gazebo reference="payload_ext_camera">
        <sensor name="payload_ext_camera_sensor" type="camera">
            <update_rate>30</update_rate>
            <camera>
                <horizontal_fov>1.04719755</horizontal_fov>  <!-- 60° FOV -->
                <image>
                    <width>1920</width>  <!-- 1080p resolution -->
                    <height>1080</height>
                    <format>R8G8B8</format>
                </image>
                <clip>
                    <near>0.1</near>
                    <far>100</far>
                </clip>
            </camera>
            <plugin filename="libgazebo_ros_camera.so" name="payload_ext_camera_plugin">
                <ros>
                    <namespace>/hermes/payload</namespace>
                    <remapping>image_raw:=ext_camera/image_raw</remapping>
                </ros>
                <camera_name>payload_ext_camera</camera_name>
                <frame_name>payload_ext_camera_optical</frame_name>
            </plugin>
        </sensor>
    </gazebo>

    <!-- Internal Payload Camera (1080p wide-angle) -->
    <link name="payload_int_camera">
        <visual>
            <geometry>
                <cylinder radius="0.015" length="0.03" />
            </geometry>
            <origin xyz="0 0 0.015" rpy="0 0 0" />
            <material name="black_camera" />
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.015" length="0.03" />
            </geometry>
        </collision>
        <inertial>
            <mass value="0.05" />
            <origin xyz="0 0 0" />
            <inertia ixx="0.00005" iyy="0.00005" izz="0.00005" ixy="0" ixz="0" iyz="0" />
        </inertial>
    </link>

    <joint name="payload_int_camera_joint" type="fixed">
        <parent link="payload_container" />
        <child link="payload_int_camera" />
        <origin xyz="0 0 0.22" rpy="0 0 3.14159" />  <!-- Facing downward -->
    </joint>

    <!-- Gazebo Camera Plugin for Internal Camera -->
    <gazebo reference="payload_int_camera">
        <sensor name="payload_int_camera_sensor" type="camera">
            <update_rate>30</update_rate>
            <camera>
                <horizontal_fov>1.91986</horizontal_fov>  <!-- 110° wide-angle -->
                <image>
                    <width>1920</width>  <!-- 1080p resolution -->
                    <height>1080</height>
                    <format>R8G8B8</format>
                </image>
                <clip>
                    <near>0.1</near>
                    <far>100</far>
                </clip>
            </camera>
            <plugin filename="libgazebo_ros_camera.so" name="payload_int_camera_plugin">
                <ros>
                    <namespace>/hermes/payload</namespace>
                    <remapping>image_raw:=int_camera/image_raw</remapping>
                </ros>
                <camera_name>payload_int_camera</camera_name>
                <frame_name>payload_int_camera_optical</frame_name>
            </plugin>
        </sensor>
    </gazebo>

    <!-- ==================== -->
    <!--  Locking Mechanism  -->
    <!-- ==================== -->

    <!-- Electromechanical Lock -->
    <link name="payload_lock">
        <visual>
            <geometry>
                <box size="0.05 0.03 0.02" />
            </geometry>
            <material name="gray_electronics" />
        </visual>
        <collision>
            <geometry>
                <box size="0.05 0.03 0.02" />
            </geometry>
        </collision>
        <inertial>
            <mass value="0.15" />
            <origin xyz="0 0 0" />
            <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" ixz="0" iyz="0" />
        </inertial>
    </link>

    <joint name="payload_lock_joint" type="prismatic">
        <parent link="payload_container" />
        <child link="payload_lock" />
        <origin xyz="0 -0.16 0.1" rpy="0 0 0" />
        <axis xyz="1 0 0" />
        <limit lower="-0.025" upper="0" effort="10" velocity="0.5" />
    </joint>

    <!-- Gazebo Lock Plugin -->
    <gazebo reference="payload_lock">
        <plugin filename="libgazebo_ros_joint_controller.so" name="payload_lock_controller">
            <joint_name>payload_lock_joint</joint_name>
            <command_topic>/hermes/payload/lock_command</command_topic>
            <joint_position_topic>/hermes/payload/lock_position</joint_position_topic>
        </plugin>
    </gazebo>

    <!-- ==================== -->
    <!--  Anti-Theft System  -->
    <!-- ==================== -->

    <!-- GPS Tracker -->
    <link name="payload_tracker">
        <visual>
            <geometry>
                <box size="0.03 0.03 0.01" />
            </geometry>
            <material name="green_sensor" />
        </visual>
    </link>

    <joint name="payload_tracker_joint" type="fixed">
        <parent link="payload_container" />
        <child link="payload_tracker" />
        <origin xyz="0.15 0 0.2" rpy="0 0 0" />
    </joint>

    <!-- Tamper Detection Sensor -->
    <link name="tamper_sensor">
        <visual>
            <geometry>
                <box size="0.02 0.02 0.005" />
            </geometry>
            <material name="red_motor" />
        </visual>
    </link>

    <joint name="tamper_sensor_joint" type="fixed">
        <parent link="payload_container" />
        <child link="tamper_sensor" />
        <origin xyz="0.18 0.14 0.2" rpy="0 0 0" />
    </joint>

    <!-- Gazebo Tamper Detection Plugin -->
    <gazebo reference="tamper_sensor">
        <plugin filename="libgazebo_ros_contact_sensor.so" name="tamper_sensor_plugin">
            <ros>
                <namespace>/hermes/payload</namespace>
                <remapping>contact:=tamper_alert</remapping>
            </ros>
            <collision_name>payload_container::payload_container_collision</collision_name>
            <topic_name>tamper</topic_name>
            <min_contact_duration>0.5</min_contact_duration>
        </plugin>
    </gazebo>

    <!-- ==================== -->
    <!--  Payload Release System  -->
    <!-- ==================== -->

    <!-- Emergency Release Mechanism -->
    <link name="payload_release">
        <visual>
            <geometry>
                <cylinder radius="0.015" length="0.03" />
            </geometry>
            <material name="red_motor" />
        </visual>
    </link>

    <joint name="payload_release_joint" type="revolute">
        <parent link="base_link" />
        <child link="payload_release" />
        <origin xyz="0 0 -0.23" rpy="0 0 0" />
        <axis xyz="0 1 0" />
        <limit lower="0" upper="1.57" effort="5" velocity="2.0" />
    </joint>

    <!-- Gazebo Release Plugin -->
    <gazebo reference="payload_release">
        <plugin filename="libgazebo_ros_joint_controller.so" name="payload_release_controller">
            <joint_name>payload_release_joint</joint_name>
            <command_topic>/hermes/payload/release_command</command_topic>
            <joint_position_topic>/hermes/payload/release_position</joint_position_topic>
        </plugin>
    </gazebo>

    <!-- ==================== -->
    <!--  Payload Mass Simulation  -->
    <!-- ==================== -->

    <!-- Virtual payload link for mass simulation -->
    <link name="virtual_payload">
        <inertial>
            <mass value="5.0" />  <!-- Max payload capacity -->
            <origin xyz="0 0 0" />
            <inertia ixx="0.1" iyy="0.08" izz="0.05" ixy="0" ixz="0" iyz="0" />
        </inertial>
    </link>

    <joint name="virtual_payload_joint" type="fixed">
        <parent link="payload_container" />
        <child link="virtual_payload" />
        <origin xyz="0 0 0.1" rpy="0 0 0" />
    </joint>

    <!-- Gazebo payload mass control plugin -->
    <gazebo reference="virtual_payload">
        <plugin filename="libpayload_mass_plugin.so" name="payload_mass_controller">
            <ros>
                <namespace>/hermes/payload</namespace>
            </ros>
            <mass_command_topic>mass_command</mass_command_topic>
            <max_mass>5.0</max_mass>  <!-- 5kg max payload -->
        </plugin>
    </gazebo>
</robot>