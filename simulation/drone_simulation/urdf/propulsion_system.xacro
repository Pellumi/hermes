<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- Motor Macro - Using reusable components for all 6 motors -->
    <xacro:macro name="hexacopter_motor" params="name xyz">
        <link name="${name}">
            <visual>
                <geometry>
                    <cylinder radius="0.05" length="0.08" />
                </geometry>
                <origin xyz="0 0 0.04" rpy="0 0 0" />
                <material name="red_motor" />
            </visual>
            <collision>
                <geometry>
                    <cylinder radius="0.05" length="0.08" />
                </geometry>
                <origin xyz="0 0 0.04" rpy="0 0 0" />
            </collision>
            <inertial>
                <mass value="0.8" />
                <inertia ixx="0.01" iyy="0.01" izz="0.002" ixy="0" ixz="0" iyz="0" />
            </inertial>
        </link>

        <joint name="${name}_joint" type="fixed">
            <parent link="base_link" />
            <child link="${name}" />
            <origin xyz="${xyz}" rpy="0 0 0" />
        </joint>

        <!-- Propeller -->
        <link name="propeller_${name[-1]}">  <!-- Gets last character (1-6) -->
            <visual>
                <geometry>
                    <cylinder radius="0.2" length="0.02" />
                </geometry>
                <origin xyz="0 0 0.01" rpy="0 0 0" />
                <material name="carbon_fiber" />
            </visual>
            <inertial>
                <mass value="0.1" />
                <inertia ixx="0.004" iyy="0.004" izz="0.004" ixy="0" ixz="0" iyz="0" />
            </inertial>
        </link>

        <joint name="propeller_${name[-1]}_joint" type="continuous">
            <parent link="${name}" />
            <child link="propeller_${name[-1]}" />
            <origin xyz="0 0 0.08" rpy="0 0 0" />
            <axis xyz="0 0 1" />
        </joint>

        <!-- Gazebo properties for the motor -->
        <gazebo reference="${name}">
            <mu1>0.2</mu1>
            <mu2>0.2</mu2>
            <kp>1000000.0</kp>
            <kd>1.0</kd>
        </gazebo>

        <!-- Gazebo properties for the propeller -->
        <gazebo reference="propeller_${name[-1]}">
            <turnGravityOff>false</turnGravityOff>
        </gazebo>
    </xacro:macro>

    <!-- Instantiate all 6 motors -->
    <xacro:hexacopter_motor name="motor_1" xyz="0.52 0 0.15" />
    <xacro:hexacopter_motor name="motor_2" xyz="0.26 0.45 0.15" />
    <xacro:hexacopter_motor name="motor_3" xyz="-0.26 0.45 0.15" />
    <xacro:hexacopter_motor name="motor_4" xyz="-0.52 0 0.15" />
    <xacro:hexacopter_motor name="motor_5" xyz="-0.26 -0.45 0.15" />
    <xacro:hexacopter_motor name="motor_6" xyz="0.26 -0.45 0.15" />
</robot>